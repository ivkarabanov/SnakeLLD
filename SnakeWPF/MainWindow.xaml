<Window x:Class="SnakeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeWPF"
        mc:Ignorable="d"
        Title="Змея v.1.0" Height="600" Width="800"
        ResizeMode="NoResize">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="Left" Command="{Binding LeftCommand}" />
        <KeyBinding Key="Right" Command="{Binding RightCommand}" />
        <KeyBinding Key="Up" Command="{Binding UpCommand}" />
        <KeyBinding Key="Down" Command="{Binding DownCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Width="75" Command="{Binding StartCommand}">Начать</Button>
                <Button  Width="75" Command="{Binding StopCommand}" Margin="5 0">Остановить</Button>
                <TextBlock Margin="15 3 5 0">Ширина:</TextBlock>
                <TextBox Width="50" Text="{Binding Width}"></TextBox>
                <TextBlock Margin="5 3 0 0">Высота:</TextBlock>
                <TextBox Width="50"  Text="{Binding Height}"></TextBox>
                <TextBlock Margin="5 3 0 0">Начальная длина:</TextBlock>
                <TextBox Width="50" Text="{Binding InitialSnakeLength}"></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Margin="15 3 5 0">Длина змейки:</TextBlock>
                    <TextBox Width="50" Text="{Binding SnakeLength}" IsReadOnly="True"></TextBox>
                <TextBlock Margin="5 3 0 0">Очки:</TextBlock>
                <TextBox Width="50" Text="{Binding Score}" IsReadOnly="True"></TextBox>
            </StackPanel>
            </DockPanel>
            <Grid Grid.Row="1"
                  local:SizeObserver.Observe="True"
                    local:SizeObserver.ObservedWidth="{Binding WidthPixels}"
                    local:SizeObserver.ObservedHeight="{Binding HeightPixels}">
                <Border BorderBrush="Black" BorderThickness="1" Background="White">

                <Canvas Width="{Binding FieldWidthPixels}" Height="{Binding FieldHeightPixels}" Background="LightGray">
                <ItemsControl ItemsSource="{Binding SnakeParts}" Background="LightBlue">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Rectangle 
                                    Width="{Binding DataContext.BoxSideLength, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}" 
                                    Height="{Binding DataContext.BoxSideLength, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                               Stroke="Black"
                               Fill="LightBlue" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
            </Border>
            </Grid>
            <Border Grid.Row="1"
                Background="#80000000"
                Visibility="{Binding IsGameOver, Converter={StaticResource BooleanToVisibilityConverter}}"
                Opacity="0.8"  
                Panel.ZIndex="100"> 
                <TextBlock
                    Text="GAME OVER"
                    Foreground="White"
                    FontSize="72"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"/>
            </Border>
        </Grid>
        
    </Grid>
</Window>
